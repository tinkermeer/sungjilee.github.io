    <entry>
        <title>The Birth of Memories</title>
        <author>
            <name>sj</name>
        </author>
        <link href="https://tinkermeer.github.io/sungjilee.github.io/the-birth-of-memories-3.html"/>
        <id>https://tinkermeer.github.io/sungjilee.github.io/the-birth-of-memories-3.html</id>
